# Copy to `.env` and fill in real values. docker-compose reads this automatically.

# OpenAI API key — required for embeddings + chat completion.
OPENAI_API_KEY=sk-your-key-here

# OpenAI models & embedding dimension. Must match each other:
#   text-embedding-3-small  -> 1536
#   text-embedding-3-large  -> 3072
# NOTE: if you change EMBEDDING_MODEL/DIMENSIONS after uploading documents,
# drop the Qdrant `rag_documents` collection so it's recreated with the new size.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-4o-mini

# HMAC signing key for JWTs. Must be at least 32 bytes. Generate with e.g.
#   openssl rand -base64 48
JWT_SIGNING_KEY=replace-me-with-a-long-random-32b+-string
